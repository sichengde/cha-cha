.settings-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.navbar-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: center;
}

.navbar-right {
  width: 60rpx;
}

.content {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.name-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.name-input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.name-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.name-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.desc-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #999;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 10rpx;
  margin-top: 10rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.setting-item.no-bottom {
  margin-bottom: 0;
  border-radius: 16rpx 16rpx 0 0;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

.setting-right {
  display: flex;
  align-items: center;
}

.setting-value {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

.modifiable-list {
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
  margin-bottom: 20rpx;
  padding: 14rpx 22rpx 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 26rpx;
}

.modifiable-tip {
  width: 100%;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.modifiable-item {
  display: flex;
  align-items: center;
  padding: 10rpx 2rpx;
  min-width: 200rpx;
  max-width: 100%;
}

.modifiable-empty {
  width: 100%;
  font-size: 24rpx;
  color: #999;
  padding: 18rpx 8rpx 14rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 4rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}

.check-icon {
  width: 24rpx;
  height: 24rpx;
}

.modifiable-name {
  flex: 0 1 auto;
  max-width: 290rpx;
  font-size: 27rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bottom-space {
  height: 0;
}

.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  padding-bottom: 40rpx;
  max-width: 690rpx;
  margin-left: auto;
  margin-right: auto;
}

.btn-save {
  width: 100%;
  max-width: 690rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-save::after {
  border: none;
}

.time-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.close-icon {
  width: 32rpx;
  height: 32rpx;
}

.modal-body {
  padding: 32rpx;
}

.time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.time-row:last-child {
  border-bottom: none;
}

.time-label {
  font-size: 28rpx;
  color: #333;
}

.time-picker {
  display: flex;
  align-items: center;
}

.time-value {
  font-size: 26rpx;
  color: #07c160;
  margin-right: 8rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 20rpx;
}

.btn-reset {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-reset::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-confirm::after {
  border: none;
}

.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-modal .modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.share-modal .success-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.share-modal .check-icon {
  width: 60rpx;
  height: 60rpx;
}

.share-modal .success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.share-modal .success-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.share-btns {
  display: flex;
  gap: 18rpx;
}

.share-btns .btn-share,
.share-btns .btn-secondary {
  flex: 1;
  height: 88rpx;
  padding: 0;
  border: none;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 44rpx;
  font-size: 31rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.share-btns .btn-share::after,
.share-btns .btn-secondary::after {
  border: none;
}

.qr-preview-modal {
  position: fixed;
  inset: 0;
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-preview-content {
  position: relative;
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 34rpx;
  box-sizing: border-box;
  text-align: center;
}

.qr-preview-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.qr-preview-image {
  width: 520rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.qr-preview-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}
