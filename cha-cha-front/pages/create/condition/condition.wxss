.condition-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.navbar-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: center;
}

.navbar-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.help-link {
  font-size: 26rpx;
  color: #07c160;
}

.content {
  padding: 30rpx;
  padding-bottom: 150rpx;
}

.tip-section {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
}

.tip-link {
  font-size: 26rpx;
  color: #07c160;
}

.example-tip {
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.example-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.condition-list {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.condition-item {
  display: flex;
  align-items: center;
  width: 50%;
  padding: 16rpx 12rpx;
  box-sizing: border-box;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 4rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}

.check-icon {
  width: 24rpx;
  height: 24rpx;
}

.condition-text {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.bottom-button {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
  display: flex;
  justify-content: center;
}

.btn-primary {
  width: 100%;
  max-width: 690rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
}

.btn-primary::after {
  border: none;
}
