.myqueries-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.navbar-left {
  width: 80rpx;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.navbar-right {
  width: 80rpx;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.filter-tabs {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #07c160;
  border-radius: 3rpx;
}

.query-list {
  padding: 20rpx 30rpx;
}

.query-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.query-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.query-status {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.query-status.active {
  background: #e8f8e8;
  color: #07c160;
}

.query-status.ended {
  background: #f5f5f5;
  color: #999;
}

.card-body {
  margin-bottom: 20rpx;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  align-items: stretch;
}

.stat-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  min-height: 56rpx;
  line-height: 56rpx;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.create-time {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 20rpx;
  background: #e8f8e8;
  border-radius: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 30rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}

.share-modal {
  position: fixed;
  inset: 0;
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
}

.modal-panel {
  position: relative;
  width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 36rpx 30rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
}

.modal-desc {
  margin-top: 16rpx;
  margin-bottom: 28rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #666;
  text-align: center;
}

.modal-share-btn,
.modal-cancel-btn {
  height: 86rpx;
  border-radius: 43rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-share-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.modal-cancel-btn {
  margin-top: 16rpx;
  background: #f2f2f2;
  color: #666;
}

.modal-share-btn::after,
.modal-cancel-btn::after {
  border: none;
}

.qr-modal {
  position: fixed;
  inset: 0;
  z-index: 320;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-panel {
  position: relative;
  width: 620rpx;
  background: #fff;
  border-radius: 22rpx;
  padding: 34rpx;
  box-sizing: border-box;
  text-align: center;
}

.qr-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.qr-image {
  width: 520rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.qr-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #999;
}
