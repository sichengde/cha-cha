.manage-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx 30rpx 30rpx;
}

.header-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.header-info {
  margin-bottom: 24rpx;
}

.query-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.query-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-share {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  border: none;
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-num.primary {
  color: #07c160;
}

.stat-num.warning {
  color: #faad14;
}

.stat-num.success {
  color: #52c41a;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160 0%, #52c41a 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon .icon-svg {
  width: 44rpx;
  height: 44rpx;
}

.action-icon.stats {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon.export {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.action-icon.signature {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
}

.action-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.data-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.filter-text {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.filter-arrow {
  font-size: 20rpx;
  color: #999;
}

.data-table {
  max-height: 600rpx;
  white-space: nowrap;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row.header {
  background: #f5f5f5;
  font-weight: 600;
}

.table-cell {
  min-width: 150rpx;
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.status-tag.queried {
  background: #e8f8e8;
  color: #07c160;
}

.status-tag.unqueried {
  background: #fff7e6;
  color: #faad14;
}

.status-tag.signed {
  background: #e8f8e8;
  color: #52c41a;
}

.status-tag.unsigned {
  background: #f5f5f5;
  color: #999;
}

.settings-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 30rpx;
  color: #333;
}

.setting-label.danger {
  color: #ff4d4f;
}

.setting-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.share-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
}

.share-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.qrcode-box {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 30rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode {
  width: 360rpx;
  height: 360rpx;
}

.share-tip {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.share-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.share-btn {
  flex: 1;
  height: 80rpx;
  background: #07c160;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.share-btn::after {
  border: none;
}

.btn-close {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  border: none;
}
