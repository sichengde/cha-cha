.manage-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.navbar-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 36rpx;
  height: 36rpx;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: center;
}

.navbar-right {
  width: 60rpx;
}

.header-card {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
}

.header-info {
  margin-bottom: 0;
}

.query-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.query-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-num.primary {
  color: #07c160;
}

.stat-num.warning {
  color: #faad14;
}

.stat-num.success {
  color: #52c41a;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160 0%, #52c41a 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 30rpx 20rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon .icon-svg {
  width: 44rpx;
  height: 44rpx;
}

.action-icon.stats {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-icon.export {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
}

.action-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.data-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.filter-text {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.filter-arrow {
  font-size: 20rpx;
  color: #999;
}

.data-table {
  max-height: 600rpx;
  white-space: nowrap;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row.header {
  background: #f5f5f5;
  font-weight: 600;
  position: sticky;
  top: 0;
  z-index: 10;
}

.table-row.header::before {
  content: '';
  position: absolute;
  left: -1000rpx;
  right: -1000rpx;
  top: 0;
  bottom: 0;
  background: #f5f5f5;
  z-index: -1;
}

.table-cell {
  width: 180rpx;
  min-width: 180rpx;
  max-width: 180rpx;
  flex-shrink: 0;
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
  position: relative;
  background: inherit;
  box-sizing: border-box;
}

.table-cell.status-cell {
  width: 130rpx;
  min-width: 130rpx;
  max-width: 130rpx;
}

.table-row.header .table-cell {
  background: #f5f5f5;
}

.cell-text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.status-tag.queried {
  background: #e8f8e8;
  color: #07c160;
}

.status-tag.unqueried {
  background: #fff7e6;
  color: #faad14;
}

.status-tag.signed {
  background: #e8f8e8;
  color: #52c41a;
}

.status-tag.unsigned {
  background: #f5f5f5;
  color: #999;
}

.settings-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 30rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 30rpx;
  color: #333;
}

.setting-label.danger {
  color: #ff4d4f;
}

.setting-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.btn-share {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-share::after {
  border: none;
}

.load-more {
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.share-modal {
  position: fixed;
  inset: 0;
  z-index: 400;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-modal .modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
}

.share-modal .modal-content {
  position: relative;
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.share-modal .share-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.share-modal .share-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.share-btns {
  display: flex;
  gap: 18rpx;
}

.share-btns .btn-share,
.share-btns .btn-secondary {
  flex: 1;
  height: 88rpx;
  padding: 0;
  border: none;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 44rpx;
  font-size: 31rpx;
  font-weight: 600;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.share-btns .btn-share::after,
.share-btns .btn-secondary::after {
  border: none;
}

.qr-modal {
  position: fixed;
  inset: 0;
  z-index: 420;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-modal .modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
}

.qr-panel {
  position: relative;
  z-index: 1;
  width: 620rpx;
  background: #fff;
  border-radius: 22rpx;
  padding: 34rpx;
  box-sizing: border-box;
  text-align: center;
}

.qr-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.qr-image {
  width: 520rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.qr-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #999;
}
