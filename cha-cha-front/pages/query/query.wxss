.query-container {
  min-height: 100vh;
  background: #f7f8fa;
}

.custom-navbar {
  background: #fff;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.navbar-left {
  width: 80rpx;
}

.back-arrow {
  font-size: 52rpx;
  color: #333;
  font-weight: 300;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.navbar-right {
  width: 80rpx;
}

.content {
  padding: 24rpx 32rpx;
}

.search-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.search-input-box {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.search-input {
  font-size: 30rpx;
  color: #333;
}

.search-btn {
  width: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
}

.search-btn::after {
  border: none;
}

.tips-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.tips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.help-btn {
  display: flex;
  align-items: center;
}

.help-text {
  font-size: 26rpx;
  color: #576b95;
}

.help-arrow {
  font-size: 32rpx;
  color: #576b95;
  font-weight: 300;
  margin-left: 4rpx;
}

.tips-content {
  padding-top: 8rpx;
}

.tips-text {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
}
