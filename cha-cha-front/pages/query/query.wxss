.query-container {
  min-height: 100vh;
  background: #f7f8fa;
}

.custom-navbar {
  background: #fff;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.navbar-left {
  width: 80rpx;
}

.back-arrow {
  font-size: 52rpx;
  color: #333;
  font-weight: 300;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.navbar-right {
  width: 80rpx;
}

.content {
  padding: 24rpx 32rpx;
}

.loading-box {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.error-box {
  text-align: center;
  padding: 100rpx 0;
}

.error-text {
  color: #ff4d4f;
  font-size: 28rpx;
}

.query-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.description-box {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
}

.error-tip-box {
  background: #fff3f3;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #ff4d4f;
}

.error-tip-text {
  font-size: 28rpx;
  color: #ff4d4f;
  line-height: 40rpx;
}

.conditions-box {
  margin-bottom: 32rpx;
}

.condition-item {
  margin-bottom: 24rpx;
}

.condition-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.condition-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
}

.query-btn {
  width: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
}

.query-btn::after {
  border: none;
}

.result-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.reset-btn {
  font-size: 28rpx;
  color: #576b95;
}

.result-content {
  margin-bottom: 32rpx;
}

.result-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #666;
}

.result-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.result-value.modified {
  color: #07c160;
}

.modify-box {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modify-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.modify-item {
  margin-bottom: 24rpx;
}

.modify-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.modify-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
}

.modify-btn {
  width: 100%;
  background: #576b95;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
  margin-top: 24rpx;
}

.modify-btn::after {
  border: none;
}

.sign-box {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sign-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.signature-area {
  margin-bottom: 24rpx;
}

.signature-image {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.sign-btn {
  width: 100%;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 48rpx;
  padding: 24rpx;
  border: none;
  line-height: 1;
}

.sign-btn::after {
  border: none;
}

.confirm-btn {
  width: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
}

.confirm-btn::after {
  border: none;
}

.signed-box {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.signed-text {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 600;
}
