.query-container {
  min-height: 100vh;
  background: #f7f8fa;
}

.custom-navbar {
  background: #fff;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.navbar-left {
  width: 80rpx;
  flex-shrink: 0;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.home-icon {
  width: 38rpx;
  height: 38rpx;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
  text-align: center;
  padding: 0 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.navbar-right {
  width: 80rpx;
  flex-shrink: 0;
}

.content {
  padding: 24rpx 32rpx;
}

.file-name-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.file-name-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.file-name-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  word-break: break-all;
}

.loading-box {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.error-box {
  text-align: center;
  padding: 100rpx 0;
}

.error-text {
  color: #ff4d4f;
  font-size: 28rpx;
}

.query-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.description-box {
  width: 100%;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.description-text {
  font-size: 28rpx;
  color: #666;
  line-height: 44rpx;
}

.error-tip-box {
  width: 100%;
  background: #fff3f3;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 4rpx solid #ff4d4f;
}

.error-tip-text {
  font-size: 28rpx;
  color: #ff4d4f;
  line-height: 40rpx;
}

.conditions-box {
  width: 100%;
  margin-bottom: 32rpx;
}

.condition-item {
  margin-bottom: 24rpx;
}

.condition-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.condition-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
}

.query-btn {
  width: 100%;
  max-width: 626rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
}

.query-btn::after {
  border: none;
}

.result-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.reset-btn {
  font-size: 28rpx;
  color: #576b95;
}

.result-content {
  margin-bottom: 32rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #666;
  min-height: 84rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.result-value-wrap {
  flex: 1;
  width: 0;
  min-width: 0;
  min-height: 84rpx;
  display: flex;
  align-items: center;
}

.result-value {
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
  line-height: 1.5;
}

.result-value.modified {
  color: #07c160;
}

.result-value.editable {
  border: 1rpx dashed #07c160;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  background: #f6fff9;
  min-height: 84rpx;
  display: flex;
  align-items: center;
}

.result-input {
  display: block;
  flex: 1;
  width: 100%;
  height: 84rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  box-sizing: border-box;
  border: 1rpx solid #07c160;
  border-radius: 12rpx;
  padding: 0 16rpx;
  background: #fff;
  font-size: 28rpx;
  color: #333;
}

.inline-edit-tip {
  margin-top: 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.modify-btn {
  width: 100%;
  background: #576b95;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
  margin-top: 24rpx;
}

.modify-btn.disabled {
  background: #c6c6c6;
}

.modify-btn::after {
  border: none;
}

.sign-box {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sign-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.signature-area {
  margin-bottom: 24rpx;
}

.signature-image {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.sign-btn {
  width: 100%;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 48rpx;
  padding: 24rpx;
  border: none;
  line-height: 1;
}

.sign-btn::after {
  border: none;
}

.confirm-btn {
  width: 100%;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  padding: 28rpx;
  border: none;
  line-height: 1;
}

.confirm-btn::after {
  border: none;
}

.signed-box {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.signed-text {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 600;
}
