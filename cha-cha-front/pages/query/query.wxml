<view class="query-container">
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-left" bindtap="goBack">
        <text class="back-arrow">‹</text>
      </view>
      <view class="navbar-title">查询</view>
      <view class="navbar-right"></view>
    </view>
  </view>

  <view class="content">
    <view class="search-box">
      <view class="search-input-box">
        <input class="search-input" placeholder="请输入查询编号" value="{{queryCode}}" bindinput="onCodeInput" />
      </view>
      <button class="search-btn" bindtap="doSearch">进入查询</button>
    </view>

    <view class="tips-box">
      <view class="tips-header">
        <view class="tips-title">温馨提示</view>
        <view class="help-btn" bindtap="showHelp">
          <text class="help-text">如何获取编号？</text>
          <text class="help-arrow">›</text>
        </view>
      </view>
      <view class="tips-content">
        <text class="tips-text">若你已有「查询页的入口」，无需输入编号就能查询。</text>
      </view>
    </view>
  </view>
</view>
