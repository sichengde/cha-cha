.index-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-content {
  padding: 20rpx 32rpx;
}

.navbar-left {
  display: flex;
  align-items: center;
}

.logo-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.app-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.content {
  padding: 24rpx 32rpx;
  padding-bottom: 40rpx;
}

.card-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.main-card-half {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  background: #e8f8e8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.card-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.card-icon-jielong {
  background: #fff3e0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.tabs-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.query-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.query-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.item-type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tag-query {
  background: #e6f7ff;
  color: #1890ff;
}

.tag-jielong {
  background: #fff7e6;
  color: #fa8c16;
}

.query-info {
  flex: 1;
}

.query-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.query-time {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
}

.load-more-tip {
  text-align: center;
  padding: 30rpx 0;
}

.load-more-tip text {
  font-size: 24rpx;
  color: #ccc;
}

.upload-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.upload-modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e8f8e8;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: upload-spin 1s linear infinite;
}

@keyframes upload-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.upload-file-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.upload-progress-bar {
  width: 100%;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.upload-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160 0%, #06ad56 100%);
  border-radius: 6rpx;
  transition: width 0.2s ease-out;
}

.upload-progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
}

.complete-icon {
  background: #07c160;
  border-radius: 50%;
}

.complete-icon image {
  width: 60rpx;
  height: 60rpx;
}

.upload-complete-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
}
