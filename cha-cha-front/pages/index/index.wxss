.index-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-content {
  padding: 20rpx 32rpx;
}

.navbar-left {
  display: flex;
  align-items: center;
}

.logo {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.app-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.content {
  padding: 24rpx 32rpx;
  padding-bottom: 40rpx;
}

.main-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  background: #e8f8e8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.card-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
  margin-left: 16rpx;
}

.tabs-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.query-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.query-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.query-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.query-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.query-time {
  font-size: 24rpx;
  color: #999;
}

.query-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  display: flex;
  align-items: center;
}

.action-icon-img {
  width: 28rpx;
  height: 28rpx;
  margin-right: 6rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999;
}

.ad-placeholder {
  height: 160rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  border: 2rpx dashed #ddd;
}

.ad-text {
  font-size: 28rpx;
  color: #ccc;
}
