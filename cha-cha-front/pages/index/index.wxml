<view class="index-container">
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-left">
        <view class="logo">
          <text class="logo-text">查</text>
        </view>
        <text class="app-name">查查助手</text>
      </view>
    </view>
  </view>

  <view class="content">
    <view class="main-card" bindtap="goToCreate">
      <view class="card-icon">
        <image src="/assets/icons/table.svg" class="card-icon-img"></image>
      </view>
      <view class="card-content">
        <view class="card-title">创建查询</view>
        <view class="card-desc">上传Excel表格，快速创建查询页面</view>
      </view>
      <view class="card-arrow">›</view>
    </view>

    <view class="tabs-section">
      <view class="section-title">最近查询</view>
      <view class="query-list">
        <view class="query-card" wx:for="{{recentQueries}}" wx:key="id" bindtap="goToManage" data-id="{{item.id}}">
          <view class="query-info">
            <view class="query-title">{{item.name || '示例查询'}}</view>
            <view class="query-time">{{item.displayCreatedAt || '刚刚'}}</view>
          </view>
          <view class="card-arrow">›</view>
        </view>
        <view class="empty-tip" wx:if="{{recentQueries.length === 0}}">
          <text>暂无查询记录</text>
        </view>
      </view>
    </view>

    <view class="ad-placeholder">
      <text class="ad-text">广告位</text>
    </view>
  </view>
</view>
