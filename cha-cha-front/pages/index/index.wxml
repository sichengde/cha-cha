<view class="index-container">
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-left">
        <image class="logo-img" src="/assets/icons/logo.png" mode="aspectFill"></image>
        <text class="app-name">班班通丨线上收集</text>
      </view>
    </view>
  </view>

  <view class="content">
    <view class="card-row">
      <view class="main-card-half" bindtap="goToCreate">
        <view class="card-icon">
          <image src="/assets/icons/table.svg" class="card-icon-img"></image>
        </view>
        <view class="card-title">创建查询</view>
        <view class="card-desc">上传Excel快速创建</view>
      </view>

      <view class="main-card-half" bindtap="goToJielong">
        <view class="card-icon card-icon-jielong">
          <image src="/assets/icons/sign.svg" class="card-icon-img"></image>
        </view>
        <view class="card-title">创建接龙</view>
        <view class="card-desc">在线接龙统计</view>
      </view>
    </view>

    <view class="tabs-section">
      <view class="section-title">最近活动</view>
      <view class="query-list">
        <view class="query-card" wx:for="{{recentItems}}" wx:key="_key" bindtap="goToItem" data-id="{{item.id}}" data-type="{{item._type}}">
          <view class="item-type-tag {{item._type === 'jielong' ? 'tag-jielong' : 'tag-query'}}">{{item._type === 'jielong' ? '接龙' : '查询'}}</view>
          <view class="query-info">
            <view class="query-title">{{item._name}}</view>
            <view class="query-time">{{item.displayCreatedAt || '刚刚'}}</view>
          </view>
          <view class="card-arrow">›</view>
        </view>
        <view class="empty-tip" wx:if="{{recentItems.length === 0}}">
          <text>暂无记录</text>
        </view>
        <view class="load-more-tip" wx:if="{{recentItems.length > 0 && loading}}">
          <text>加载中...</text>
        </view>
        <view class="load-more-tip" wx:if="{{recentItems.length > 0 && !hasMoreItems && !loading}}">
          <text>没有更多了</text>
        </view>
      </view>
    </view>
  </view>

  <view class="upload-modal" wx:if="{{uploading || uploadComplete}}">
    <view class="upload-modal-content">
      <view class="upload-icon" wx:if="{{uploading}}">
        <view class="upload-spinner"></view>
      </view>
      <view class="upload-icon complete-icon" wx:if="{{uploadComplete}}">
        <image src="/assets/icons/check.svg" mode="aspectFit"></image>
      </view>
      <view class="upload-file-name">{{uploadFileName}}</view>
      <view class="upload-progress-bar" wx:if="{{uploading}}">
        <view class="upload-progress-fill" style="width: {{uploadProgress}}%;"></view>
      </view>
      <view class="upload-progress-text" wx:if="{{uploading}}">{{uploadProgress}}%</view>
      <view class="upload-complete-text" wx:if="{{uploadComplete}}">解析完成</view>
    </view>
  </view>
</view>
