.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.navbar-left { width: 60rpx; }
.back-icon { width: 40rpx; height: 40rpx; }
.home-icon { width: 38rpx; height: 38rpx; }
.navbar-title { font-size: 34rpx; font-weight: 600; color: #333; }
.navbar-right { width: 60rpx; }

.detail-content {
  padding: 24rpx 32rpx;
  padding-bottom: 40rpx;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.info-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.info-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.meta-label { color: #999; }
.meta-value { color: #666; }

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag.open {
  background: #e8f8e8;
  color: #07c160;
}

.status-tag.closed {
  background: #f0f0f0;
  color: #999;
}

/* 名单卡片 */
.member-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.manage-btn {
  font-size: 26rpx;
  color: #07c160;
  padding: 8rpx 20rpx;
  border: 1rpx solid #07c160;
  border-radius: 24rpx;
}

.member-list {}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-seq {
  font-size: 26rpx;
  color: #999;
  width: 50rpx;
  flex-shrink: 0;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.member-info {
  flex: 1;
  overflow: hidden;
}

.member-name {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.member-remark {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-time {
  font-size: 22rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 统一操作区 */
.action-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

/* 发起人 2×2 网格 */
.creator-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.grid-btn {
  flex: 0 0 calc(50% - 10rpx);
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 12rpx;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.toggle-btn {
  background: #f5f5f5;
  color: #555;
}

.export-btn {
  background: #e8f2ff;
  color: #1890ff;
}

.share-btn {
  background: #e8f8e8;
  color: #07c160;
}

.delete-btn {
  background: #fff0f0;
  color: #e53935;
}

/* 参与者按钮（全宽） */
.join-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.join-btn.active {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.join-btn.joined {
  background: #fff0f0;
  color: #e53935;
  border: 1rpx solid #e53935;
}

.join-btn[disabled] {
  background: #f0f0f0;
  color: #999;
}

.loading-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 备注弹窗 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.popup-fields {
  margin-bottom: 20rpx;
}

.popup-field-item {
  margin-bottom: 20rpx;
}

.popup-field-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.popup-field-label .required::before {
  content: '*';
  color: #e53935;
  margin-right: 4rpx;
}

.popup-field-input {
  width: 100%;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.popup-textarea {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.popup-actions {
  display: flex;
  gap: 20rpx;
}

.popup-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.popup-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.popup-btn.confirm {
  background: #07c160;
  color: #fff;
}
