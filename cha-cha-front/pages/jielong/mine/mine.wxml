<view class="page-container">
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-left" bindtap="goToCreate">
        <text class="create-link">创建</text>
      </view>
      <view class="navbar-title">接龙</view>
      <view class="navbar-right"></view>
    </view>
  </view>

  <view class="filter-tabs">
    <view class="tab-item {{currentTab === 'created' ? 'active' : ''}}" bindtap="switchTab" data-tab="created">我发起的</view>
    <view class="tab-item {{currentTab === 'joined' ? 'active' : ''}}" bindtap="switchTab" data-tab="joined">我参与的</view>
  </view>

  <view class="list-section">
    <view class="jielong-card" wx:for="{{list}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="card-header">
        <text class="card-title">{{item.title}}</text>
        <text class="card-status {{item.status === 'open' ? 'status-open' : 'status-closed'}}">{{item.statusText}}</text>
      </view>
      <view class="card-body">
        <text class="card-count">{{item.member_count || 0}} 人参与</text>
        <text class="card-time">{{item.displayTime}}</text>
      </view>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
      <text class="empty-text">暂无接龙记录</text>
      <view class="empty-btn" bindtap="goToCreate" wx:if="{{currentTab === 'created'}}">创建接龙</view>
    </view>

    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
      <text>没有更多了</text>
    </view>
  </view>
</view>
