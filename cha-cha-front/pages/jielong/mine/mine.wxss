.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.navbar-left { width: 80rpx; }
.navbar-title { font-size: 36rpx; font-weight: 700; color: #333; }
.navbar-right { width: 80rpx; }

.create-link {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}

.filter-tabs {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #07c160;
  border-radius: 3rpx;
}

.list-section {
  padding: 24rpx 32rpx;
}

.jielong-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.card-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.status-open {
  color: #07c160;
  background: #e8f8e8;
}

.status-closed {
  color: #999;
  background: #f5f5f5;
}

.card-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-count {
  font-size: 26rpx;
  color: #666;
}

.card-time {
  font-size: 24rpx;
  color: #ccc;
}

.loading-tip, .no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}

.empty-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}
