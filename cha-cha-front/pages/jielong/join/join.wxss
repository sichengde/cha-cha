.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-navbar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
}

.navbar-left {
  width: 60rpx;
  display: flex;
  align-items: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.home-icon {
  width: 38rpx;
  height: 38rpx;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.navbar-right {
  width: 60rpx;
}

.join-content {
  padding: 30rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.info-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  line-height: 1.6;
}

.info-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.meta-label {
  color: #999;
}

.meta-value {
  color: #666;
}

.meta-count {
  color: #07c160;
  font-weight: 600;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 36rpx;
  text-align: center;
}

.result-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.result-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #07c160;
  margin-bottom: 30rpx;
}

.result-text.closed {
  color: #999;
}

.detail-btn {
  width: 320rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0;
  margin: 0;
  border: none;
}

.detail-btn::after {
  border: none;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.field-area {
  margin-bottom: 20rpx;
}

.field-item {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.field-label .required::before {
  content: '*';
  color: #e53935;
  margin-right: 4rpx;
}

.field-input {
  width: 100%;
  height: 72rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.remark-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.remark-input {
  width: 100%;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.no-remark-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #999;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #fff;
}

.loading-tip {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #999;
}
